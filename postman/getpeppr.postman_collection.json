    {
      "name": "Directory",
      "item": [
        {
          "name": "Lookup Participant",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/directory/:scheme/:id",
              "host": ["{{base_url}}"],
              "path": ["v1", "directory", ":scheme", ":id"],
              "variable": [
                { "key": "scheme", "value": "0208" },
                { "key": "id", "value": "BE0456789012" }
              ]
            }
          }
        },
        {
          "name": "Search Directory",
          "request": {
            "method": "GET",
            "description": "Search the Peppol Directory for participants by name, country, or VAT number",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/directory/search?name=Acme&country=BE&limit=10",
              "host": ["{{base_url}}"],
              "path": ["v1", "directory", "search"],
              "query": [
                { "key": "name", "value": "Acme", "description": "Business name to search for" },
                { "key": "country", "value": "BE", "description": "ISO 3166-1 alpha-2 country code" },
                { "key": "vatNumber", "value": "", "description": "VAT number (country prefix stripped server-side)", "disabled": true },
                { "key": "limit", "value": "10", "description": "Maximum number of results" },
                { "key": "offset", "value": "0", "description": "Pagination offset", "disabled": true }
              ]
            }
          }
        }
      ]
    },
