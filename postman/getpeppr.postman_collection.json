{
  "info": {
    "name": "getpeppr API",
    "description": "Peppol e-invoicing API. Full docs at https://getpeppr.dev/docs/",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.getpeppr.dev",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "sk_sandbox_abc123...",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_key}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Invoices",
      "item": [
        {
          "name": "Create Draft Invoice",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": \"INV-2026-001\",\n  \"to\": {\n    \"name\": \"Globex NV\",\n    \"peppolId\": \"0208:BE0987654321\",\n    \"country\": \"BE\",\n    \"street\": \"Rue de la Loi 200\",\n    \"city\": \"Brussels\",\n    \"postalCode\": \"1000\"\n  },\n  \"lines\": [\n    {\n      \"description\": \"Consulting\",\n      \"quantity\": 1,\n      \"unitPrice\": 1000,\n      \"vatRate\": 21\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Send Invoice",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-validate-recipient",
                "value": "warn",
                "description": "Optional. 'warn' (non-blocking) or 'strict' (rejects if recipient not found). Omit for no validation.",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/send",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", "send"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": \"INV-2026-001\",\n  \"to\": {\n    \"name\": \"Globex NV\",\n    \"peppolId\": \"0208:BE0987654321\",\n    \"country\": \"BE\",\n    \"street\": \"Rue de la Loi 200\",\n    \"city\": \"Brussels\",\n    \"postalCode\": \"1000\"\n  },\n  \"lines\": [\n    {\n      \"description\": \"Consulting\",\n      \"quantity\": 1,\n      \"unitPrice\": 1000,\n      \"vatRate\": 21\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Send Credit Note",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/send",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", "send"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": \"CN-2026-001\",\n  \"isCreditNote\": true,\n  \"invoiceReference\": \"INV-2026-001\",\n  \"to\": {\n    \"name\": \"Globex NV\",\n    \"peppolId\": \"0208:BE0987654321\",\n    \"country\": \"BE\",\n    \"street\": \"Rue de la Loi 200\",\n    \"city\": \"Brussels\",\n    \"postalCode\": \"1000\"\n  },\n  \"lines\": [\n    {\n      \"description\": \"Consulting — refund\",\n      \"quantity\": 1,\n      \"unitPrice\": 1000,\n      \"vatRate\": 21\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Send Draft by ID",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/v1/invoices/send/:id",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", "send", ":id"],
              "variable": [
                { "key": "id", "value": "inv_abc123" }
              ]
            }
          }
        },
        {
          "name": "Update Invoice",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/:id",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", ":id"],
              "variable": [
                { "key": "id", "value": "inv_abc123" }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Updated payment terms\",\n  \"dueDate\": \"2026-04-15\"\n}"
            }
          }
        },
        {
          "name": "Delete Invoice",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/v1/invoices/:id",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", ":id"],
              "variable": [
                { "key": "id", "value": "inv_abc123" }
              ]
            }
          }
        },
        {
          "name": "Import Invoice",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/import",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", "import"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ublXml\": \"<Invoice xmlns='urn:oasis:names:specification:ubl:schema:xsd:Invoice-2'>...</Invoice>\"\n}"
            }
          }
        },
        {
          "name": "List Invoices",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/invoices?limit=10&offset=0",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Get Invoice Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/invoices/:id",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", ":id"],
              "variable": [
                { "key": "id", "value": "inv_abc123" }
              ]
            }
          }
        },
        {
          "name": "Export Invoice (PDF/XML/JSON)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/invoices/:id/as/:format",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", ":id", "as", ":format"],
              "variable": [
                { "key": "id", "value": "inv_abc123" },
                { "key": "format", "value": "pdf" }
              ]
            }
          }
        },
        {
          "name": "Acknowledge Invoice",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/v1/invoices/:id/ack",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", ":id", "ack"],
              "variable": [
                { "key": "id", "value": "inv_abc123" }
              ]
            }
          }
        },
        {
          "name": "Mark Invoice As (accepted/rejected/paid)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/invoices/:id/mark-as",
              "host": ["{{base_url}}"],
              "path": ["v1", "invoices", ":id", "mark-as"],
              "variable": [
                { "key": "id", "value": "inv_abc123" }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"state\": \"paid\"\n}"
            }
          }
        }
      ]
    },
